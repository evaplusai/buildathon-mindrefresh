# Local-only secrets for sensor bring-up.
# Copy this file to .env and fill in real values:
#   cp .env.example .env
# .env is already in .gitignore — never commit your real credentials.

# Your home WiFi (2.4 GHz only — ESP32-S3 CSI does not work on 5 GHz)
SENSOR_SSID=
SENSOR_PASSWORD=

# Auto-detected unless overridden:
# PORT=/dev/cu.usbserial-0001
# LAN_IP=192.168.1.163
# WS_PORT=8765
# UDP_PORT=5005
